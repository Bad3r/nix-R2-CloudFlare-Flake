{
  "name": "r2-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "pnpm -C web dev",
    "build:web": "pnpm -C web build",
    "check:api": "tsc --noEmit",
    "check:web": "pnpm -C web check",
    "check": "pnpm run check:api && pnpm run check:web",
    "deploy": "wrangler deploy",
    "test:api": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test": "pnpm run test:api",
    "test:all": "pnpm run test:api && pnpm run test:workers",
    "test:live": "vitest run tests/live.integration.spec.ts",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.2",
    "@cloudflare/workers-types": "^4.20260702.1",
    "hono": "^4.12.28",
    "miniflare": "4.20260701.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.108.0"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "zod": "^4.4.3"
  }
}
