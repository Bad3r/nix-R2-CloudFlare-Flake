---
// Self-hosted variable fonts (bundled as same-origin assets so the strict
// font-src 'self' CSP is satisfied; no external font CDN is contacted).
import "@fontsource-variable/martian-mono";
import "@fontsource-variable/spline-sans-mono";
import "../styles/console.css";

const { title = "R2 Explorer Console" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <script is:inline>
      // Resolve the theme before first paint to avoid a flash of the wrong palette.
      (() => {
        try {
          const stored = localStorage.getItem("r2x-theme");
          const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
          const theme = stored === "light" || stored === "dark" ? stored : prefersLight ? "light" : "dark";
          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
